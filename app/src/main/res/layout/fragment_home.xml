<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    tools:context=".ui.home.HomeFragment">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Aprimorando"
            android:textSize="28sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Guia do estudante da UFTM"
            android:textSize="16sp"
            android:textStyle="italic" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:lineSpacingMultiplier="1.2"
            android:text="O Aprimorando reúne, em um só lugar, as informações que ajudam o estudante a se orientar na universidade: estrutura da UFTM, regulamento de graduação, direitos e deveres, ligas, iniciação científica, calendário acadêmico e muito mais.\n\nUse o menu lateral para navegar pelas seções."
            android:textSize="16sp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:lineSpacingMultiplier="1.2"
            android:text="Sobre o projeto: o Aprimorando nasceu como projeto de extensão universitária. A ideia original era integrar o app a uma API alimentada pelos sistemas oficiais da UFTM, mantendo todas as informações sempre atualizadas. Essa integração não avançou por questões de liberação de acesso, e o app permanece como um guia informativo navegável."
            android:textColor="?android:attr/textColorSecondary"
            android:textSize="14sp" />
    </LinearLayout>
</ScrollView>
